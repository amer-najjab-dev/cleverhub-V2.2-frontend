{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://cleverhub-v2-backend-production.up.railway.app/api/$1"
    },
    {
      "source": "/auth/(.*)",
      "destination": "https://cleverhub-v2-backend-production.up.railway.app/auth/$1"
    },
    {
      "source": "/modules",
      "destination": "https://cleverhub-v2-backend-production.up.railway.app/modules"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}